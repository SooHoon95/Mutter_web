# Supabase (anon key만 — service role key는 절대 클라이언트에 넣지 않는다)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 저작권 신고 수신 이메일 — Takedown 페이지 표시 및 mailto: 폴백에 사용.
# 미설정 시 'copyright@mutter.app' 로 폴백된다.
VITE_COPYRIGHT_EMAIL=copyright@mutter.app

# 앱 핸드오프(연결·편지 링크를 iOS 앱으로 열기) 활성화 플래그.
# 앱 미출시 기간엔 미설정/false로 두면 오늘의 웹 전용 동작과 100% 동일하다(dark-ship).
# 출시/TestFlight 검증 시 'true'로 켜거나, 아래 스토어 URL을 채우면 자동으로 켜진다.
VITE_ENABLE_HANDOFF=false

# iOS 앱 스토어(또는 TestFlight) URL. 출시 후 채우면 설치 CTA가 노출되고 핸드오프가 켜진다.
# 미설정이면 설치 버튼을 숨긴다(무해).
VITE_IOS_APP_STORE_URL=
