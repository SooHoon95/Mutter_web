{
  "name": "letter-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "연출되는 편지 — 스크롤 동기 음악 감성 편지 PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
